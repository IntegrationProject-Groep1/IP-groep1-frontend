<?php

declare(strict_types=1);

/**
 * @file
 * Integration hooks for the session_enrollment module.
 */

/**
 * Implements hook_theme().
 */
function session_enrollment_theme(): array
{
    return [
        'enrollment_confirmation' => [
            'variables' => [
                'name'     => '',
                'sessions' => [],
            ],
        ],
        'my_sessions' => [
            'variables' => [
                'name'     => '',
                'sessions' => [],
                'notice'   => null,
            ],
        ],
    ];
}

/**
 * Implements hook_cron().
 *
 * Polls RabbitMQ queues each cron run.
 *
 * NOTE: session_view_request/response is handled on-demand in SessionEnrollForm,
 * NOT via cron. Cron only handles push events and wallet updates.
 *
 * Strategy:
 *  1. Drain session_created push events from Planning.
 *  2. Drain session_updated push events from Planning.
 *  3. Drain wallet_balance_update messages from Kassa.
 */
function session_enrollment_cron(): void
{
    $logger = \Drupal::logger('session_enrollment');

    try {
        $client = new \Drupal\rabbitmq_sender\RabbitMQClient();

        // 1. Process session_created push events from Planning (up to 20 per cron run).
        $createdReceiver = new \Drupal\rabbitmq_receiver\SessionCreatedReceiver($client);
        $count = 0;
        for ($i = 0; $i < 20; $i++) {
            if (!$createdReceiver->pollOnce()) {
                break;
            }
            $count++;
        }
        $logger->info('Cron: processed @n session_created message(s).', ['@n' => $count]);

        // 2. Process session_updated push events from Planning (up to 20 per cron run).
        $updateReceiver = new \Drupal\rabbitmq_receiver\SessionUpdateReceiver($client);
        $count = 0;
        for ($i = 0; $i < 20; $i++) {
            if (!$updateReceiver->pollOnce()) {
                break;
            }
            $count++;
        }
        $logger->info('Cron: processed @n session_updated message(s).', ['@n' => $count]);

        // 3. Process wallet_balance_update messages from Kassa (up to 20 per cron run).
        $walletReceiver = new \Drupal\rabbitmq_receiver\WalletBalanceReceiver($client);
        $count = 0;
        for ($i = 0; $i < 20; $i++) {
            if (!$walletReceiver->pollOnce()) {
                break;
            }
            $count++;
        }
        $logger->info('Cron: processed @n wallet_balance_update message(s).', ['@n' => $count]);

        $logger->info('Cron: RabbitMQ queue polling completed successfully.');
    } catch (\Throwable $e) {
        $logger->error('Cron: RabbitMQ queue polling mislukt: @message', [
            '@message' => $e->getMessage(),
        ]);
    }
}
