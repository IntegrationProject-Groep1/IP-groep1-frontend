<?php

declare(strict_types=1);

/**
 * @file
 * Integration hooks for the registration_form module.
 */

/**
 * Implements hook_theme().
 *
 * Registers the confirmation template and variables used after registration.
 */
function registration_form_theme(): array
{
    return [
        'registration_confirmation' => [
            'variables' => [
                'name'    => '',
                'session' => '',
            ],
        ],
    ];
}

/**
 * Implements hook_user_presave().
 *
 * Keeps the Drupal username (name) in sync with the email address.
 * Because this project uses email as the login identifier and never shows
 * the username to end users, name and mail must always be identical.
 */
function registration_form_user_presave(\Drupal\user\UserInterface $account): void
{
    // Skip anonymous and during initial registration (id = NULL means new user
    // — RegistrationService sets name = mail itself before save).
    if ($account->isAnonymous() || $account->id() === null) {
        return;
    }

    $newMail = (string) $account->getEmail();
    if ($newMail !== '' && $account->getAccountName() !== $newMail) {
        $account->setUsername($newMail);
    }
}

/**
 * Implements hook_user_update().
 *
 * Notifies CRM when a Drupal user account is updated.
 */
function registration_form_user_update(\Drupal\user\UserInterface $account): void
{
    $firstName = '';
    $lastName  = '';

    if ($account->hasField('field_first_name')) {
        $firstName = (string) $account->get('field_first_name')->value;
    }
    if ($account->hasField('field_last_name')) {
        $lastName = (string) $account->get('field_last_name')->value;
    }

    // Only send if the user has enough data for the contract (all required fields).
    if ($firstName === '' || $lastName === '') {
        return;
    }

    if (!\Drupal::hasService('rabbitmq_sender.user_updated_sender')) {
        return;
    }

    try {
        // Retrieve the master UUID stored during registration.
        $masterUuid = \Drupal::service('user.data')->get('registration_form', (int) $account->id(), 'master_uuid') ?? '';

        /** @var \Drupal\rabbitmq_sender\UserUpdatedSender $sender */
        $sender = \Drupal::service('rabbitmq_sender.user_updated_sender');
        $sender->send([
            'identity_uuid' => $masterUuid !== '' ? $masterUuid : (string) $account->id(),
            'user_id'       => (string) $account->id(),
            'email'         => (string) $account->getEmail(),
            'first_name'    => $firstName,
            'last_name'     => $lastName,
            'is_company'    => (bool) ($account->hasField('field_is_company') ? $account->get('field_is_company')->value : false),
            'company_name'  => (string) ($account->hasField('field_company_name') ? $account->get('field_company_name')->value : ''),
            'vat_number'    => (string) ($account->hasField('field_vat_number') ? $account->get('field_vat_number')->value : ''),
            'company_id'    => (string) ($account->hasField('field_company_id') ? $account->get('field_company_id')->value : ''),
            'street'        => (string) ($account->hasField('field_street')       ? $account->get('field_street')->value       : ''),
            'postal_code'   => (string) ($account->hasField('field_postal_code')  ? $account->get('field_postal_code')->value  : ''),
            'municipality'  => (string) ($account->hasField('field_municipality') ? $account->get('field_municipality')->value : ''),
        ]);
    } catch (\Throwable $e) {
        \Drupal::logger('registration_form')->error(
            'user_updated mislukt voor user @id: @message',
            ['@id' => $account->id(), '@message' => $e->getMessage()]
        );
    }
}

/**
 * Implements hook_form_FORM_ID_alter() for user_form.
 *
 * Customises the "Mijn gegevens" profile edit form:
 *  - Removes the user-picture upload widget.
 *  - Removes the timezone selector.
 *  - Surfaces first name, last name and date of birth as editable fields.
 *  - For company accounts: shows street, postal code and municipality fields.
 */
function registration_form_form_user_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void
{
    // ── 1. Remove photo upload ───────────────────────────────────────────────
    if (isset($form['user_picture'])) {
        $form['user_picture']['#access'] = false;
    }

    // ── 2. Remove timezone ──────────────────────────────────────────────────
    if (isset($form['timezone'])) {
        $form['timezone']['#access'] = false;
    }

    // ── 3. Surface name + date-of-birth at the top ──────────────────────────
    // These fields are created by the install hook and stored on the user entity.
    // Make sure they appear at the top of the form, above the e-mail field.
    $nameFields = ['field_first_name', 'field_last_name', 'field_date_of_birth'];
    foreach ($nameFields as $idx => $fieldName) {
        if (isset($form[$fieldName])) {
            $form[$fieldName]['#access'] = true;
            $form[$fieldName]['#weight'] = -50 + $idx;
        }
    }

    // Move account e-mail + password below the name fields.
    foreach (['account', 'contact'] as $section) {
        if (isset($form[$section])) {
            $form[$section]['#weight'] = 0;
        }
    }

    // ── 4. Address fields (company accounts only) ────────────────────────────
    $currentUser = \Drupal::currentUser();
    $isCompany = false;
    if ($currentUser->isAuthenticated()) {
        $storedFlag = \Drupal::service('user.data')->get('registration_form', (int) $currentUser->id(), 'is_company');
        $isCompany  = (bool) $storedFlag;
    }

    // Also check the user being edited (admin may edit another user).
    /** @var \Drupal\user\UserInterface|null $editedUser */
    $editedUser = $form_state->getFormObject() instanceof \Drupal\user\AccountForm
        ? $form_state->getFormObject()->getEntity()
        : null;
    if ($editedUser !== null && !$isCompany) {
        $isCompany = (bool) \Drupal::service('user.data')->get('registration_form', (int) $editedUser->id(), 'is_company');
    }

    $addressFields = ['field_street', 'field_postal_code', 'field_municipality'];
    foreach ($addressFields as $idx => $fieldName) {
        if (isset($form[$fieldName])) {
            $form[$fieldName]['#access'] = $isCompany;
            $form[$fieldName]['#weight'] = 10 + $idx;
            if ($isCompany) {
                // Make the widget label cleaner.
                $labels = [
                    'field_street'       => t('Street'),
                    'field_postal_code'  => t('Postal code'),
                    'field_municipality' => t('Municipality'),
                ];
                if (isset($form[$fieldName]['widget'][0]['value']['#title'])) {
                    $form[$fieldName]['widget'][0]['value']['#title'] = $labels[$fieldName];
                }
            }
        }
    }
}

/**
 * Implements hook_user_delete().
 *
 * Notifies CRM when a Drupal user account is deleted.
 */
function registration_form_user_delete(\Drupal\user\UserInterface $account): void
{
    if (!\Drupal::hasService('rabbitmq_sender.user_unregistered_sender')) {
        return;
    }

    try {
        // Retrieve the master UUID stored during registration.
        $masterUuid = \Drupal::service('user.data')->get('registration_form', (int) $account->id(), 'master_uuid') ?? '';

        /** @var \Drupal\rabbitmq_sender\UserUnregisteredSender $sender */
        $sender = \Drupal::service('rabbitmq_sender.user_unregistered_sender');
        $sender->send([
            'identity_uuid' => $masterUuid !== '' ? $masterUuid : (string) $account->id(),
            'user_id'       => (string) $account->id(),
            'email'         => (string) $account->getEmail(),
        ]);
    } catch (\Throwable $e) {
        \Drupal::logger('registration_form')->error(
            'user_deleted mislukt voor user @id: @message',
            ['@id' => $account->id(), '@message' => $e->getMessage()]
        );
    }
}
