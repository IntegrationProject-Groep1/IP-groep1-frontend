{#
  form--user-form.html.twig
  Instellingenpagina voor de ingelogde gebruiker (entity.user.edit_form).
  De sidebar-shell wordt verzorgd door page.html.twig.
#}

<div class="admin-sessions">

  <div class="admin-head">
    <div>
      <span class="eyebrow">{{ 'Account'|t }}</span>
      <h1>{{ 'Instellingen'|t }}</h1>
      <p>{{ 'Beheer je accountgegevens en wachtwoord.'|t }}</p>
    </div>
  </div>

  <form{{ attributes }}>
    {{ form.form_build_id }}
    {{ form.form_token }}
    {{ form.form_id }}

    {# ── Persoonlijke gegevens (voornaam, achternaam, geboortedatum) ── #}
    <div class="card card-pad-lg admin-form-card" style="margin-bottom: 20px;">
      <div class="section-label-row">
        <span class="section-label">{{ 'Persoonlijke gegevens'|t }}</span>
      </div>
      <div class="form-grid">
        {{ form.field_first_name }}
        {{ form.field_last_name }}
        {{ form.field_date_of_birth }}
      </div>
    </div>

    {# ── Accountgegevens (e-mail + wachtwoord via Drupal core account container) ── #}
    <div class="card card-pad-lg admin-form-card" style="margin-bottom: 20px;">
      <div class="section-label-row">
        <span class="section-label">{{ 'Accountgegevens'|t }}</span>
      </div>
      <div class="form-grid">
        {{ form.account }}
      </div>
    </div>

    {# ── Adresgegevens: capture first, only show card if non-empty ── #}
    {% set address_fields %}
      {{ form.field_street }}
      {{ form.field_postal_code }}
      {{ form.field_municipality }}
    {% endset %}
    {% if address_fields|trim %}
      <div class="card card-pad-lg admin-form-card" style="margin-bottom: 20px;">
        <div class="section-label-row">
          <span class="section-label">{{ 'Adresgegevens'|t }}</span>
        </div>
        <div class="form-grid">
          {{ address_fields }}
        </div>
      </div>
    {% endif %}

    <div class="admin-form-card">
      <div class="admin-form-actions">
        {{ form.actions }}
      </div>
    </div>

  </form>

</div>
