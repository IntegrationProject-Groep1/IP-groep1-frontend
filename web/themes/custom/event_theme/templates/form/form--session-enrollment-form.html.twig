{#
  form--session-enrollment-form.html.twig
  Session enrollment form styled to match the Shift Festival sessions browse design.
  Maps to form ID: session_enrollment_form

  The form render array exposes:
    - form['#sessions_full'] : full session objects from Planning state
    - form.session_ids       : checkboxes element (individual: form.session_ids[session_id])
    - form.submit            : submit button
#}

{# sessions_full is injected by event_theme_preprocess_form(); fall back to the form element property #}
{% set sessions_full = sessions_full is defined ? sessions_full : (form['#sessions_full'] ?? []) %}

<div class="sessions-page">

  {# ── Header ── #}
  <div class="sessions-head">
    <div>
      <h1>{{ 'The programme'|t }}</h1>
      {% if sessions_full %}
        <p>{{ '@count sessions across three days. Filter, search, and enrol — drop sessions any time before the festival starts.'|t({'@count': sessions_full|length}) }}</p>
      {% else %}
        <p>{{ 'Select one or more sessions you want to attend.'|t }}</p>
      {% endif %}
    </div>
    <div class="sessions-tools">
      <div class="search">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35"/>
        </svg>
        <input type="text" id="session-search" placeholder="{{ 'Search talks, speakers, or rooms...'|t }}" autocomplete="off">
      </div>
      <div class="chip-row" id="chip-row">
        <button type="button" class="chip is-on" data-filter="all">{{ 'All'|t }}</button>
        <button type="button" class="chip" data-filter="keynote">{{ 'Keynote'|t }}</button>
        <button type="button" class="chip" data-filter="workshop">{{ 'Workshop'|t }}</button>
        <button type="button" class="chip" data-filter="talk">{{ 'Talk'|t }}</button>
        <button type="button" class="chip" data-filter="panel">{{ 'Panel'|t }}</button>
        <button type="button" class="chip" data-filter="reception">{{ 'Reception'|t }}</button>
      </div>
    </div>
  </div>

  {# ── Messages ── #}
  {% if message %}
    <div class="alert alert-error" style="margin-bottom:20px;">{{ message }}</div>
  {% endif %}

  <form{{ attributes }}>
    {{ form.form_build_id }}
    {{ form.form_token }}
    {{ form.form_id }}

    {% if form.enrollment_success %}
      {{ form.enrollment_success }}
    {% endif %}

    {% if form.enrollment_error %}
      {{ form.enrollment_error }}
    {% endif %}

    {% if form.notice %}
      <div class="alert alert-error" style="margin-bottom:20px;">{{ form.notice }}</div>
    {% endif %}

    {% if sessions_full is empty %}
      {# Fallback: no session data — render the raw form element #}
      {% if form.session_ids %}
        <div class="card card-pad-lg" style="margin-bottom:20px;">
          <p class="section-label">{{ 'Available sessions'|t }}</p>
          {{ form.session_ids }}
        </div>
      {% endif %}

    {% else %}
      {# ── Session cards grouped by day ── #}
      <div class="schedule-stack" style="margin-bottom:28px;">
        {% for day, day_sessions in sessions_grouped %}
          <section class="schedule-day">
            <h2 class="schedule-day-title">{{ day }}</h2>
            <div class="session-list">
        {% for session in day_sessions %}
          {% set sid = session.session_id %}

          {% set pct = 0 %}
          {% if session.max_attendees > 0 %}
            {% set pct = ((session.current_attendees / session.max_attendees) * 100)|round %}
          {% endif %}

          {% set cap_class = 'capacity-cool' %}
          {% if pct >= 95 %}{% set cap_class = 'capacity-hot' %}
          {% elseif pct >= 75 %}{% set cap_class = 'capacity-warm' %}
          {% endif %}

          {% set type_tone = 'neutral' %}
          {% if session.session_type == 'keynote' %}{% set type_tone = 'primary' %}
          {% elseif session.session_type == 'workshop' %}{% set type_tone = 'accent' %}
          {% elseif session.session_type == 'reception' %}{% set type_tone = 'warm' %}
          {% endif %}

          {% set is_full = session.max_attendees > 0 and session.current_attendees >= session.max_attendees %}

          {% set is_enrolled = session.is_enrolled ?? false %}

          {# Build session detail JSON for the popup modal #}
          {% set speaker_name = session.speaker_name ?? '' %}
          {% if not speaker_name and session.speaker is defined and session.speaker %}
            {% set speaker_name = [session.speaker.first_name, session.speaker.last_name]|join(' ')|trim %}
          {% endif %}
          {% set speaker_org  = session.speaker.organisation ?? '' %}
          {% set speaker_email = session.speaker.email ?? '' %}
          {% set start_parts2 = session.start_datetime ? session.start_datetime|split('T') : [] %}
          {% set session_date = start_parts2[0] ?? '' %}
          {% set session_time = start_parts2[1] is defined ? start_parts2[1]|split(':')|slice(0,2)|join(':') : '' %}
          {% set session_json = {
            'session_id':  sid,
            'title':       session.title,
            'type':        session.session_type,
            'date':        session_date,
            'time':        session_time,
            'duration':    session.duration_minutes ?? 0,
            'location':    session.location ?? '',
            'speaker':     speaker_name,
            'speaker_org': speaker_org,
            'speaker_email': speaker_email,
            'description': session.description ?? '',
            'current':     session.current_attendees ?? 0,
            'max':         session.max_attendees ?? 0,
            'enrolled':    is_enrolled,
            'full':        is_full,
            'price':       session.price ?? ''
          }|json_encode %}

          <article class="session-card{% if is_full %} session-card-full{% endif %}{% if is_enrolled %} is-enrolled{% endif %}"
                   data-type="{{ session.session_type|lower }}"
                   data-title="{{ session.title|lower }}"
                   data-speaker="{{ speaker_name|lower }}"
                   data-location="{{ session.location|lower }}"
                   data-session="{{ session_json|e('html_attr') }}"
                   style="cursor:pointer;"
                   tabindex="0"
                   role="button"
                   aria-label="{{ 'View details: '|t }}{{ session.title }}">

            {# Time column #}
            <div class="session-time-col">
              {% if session.start_datetime %}
                {% set start_parts = session.start_datetime|split('T') %}
                {% set date_str = start_parts[0] ?? '' %}
                {% set time_str = (start_parts[1] ?? '')|split(':')|slice(0,2)|join(':') %}
                <span class="session-day">{{ date_str }}</span>
                <span class="session-hour">{{ time_str }}</span>
                {% if session.end_datetime %}
                  {% set end_parts = session.end_datetime|split('T') %}
                  {% set end_time_str = (end_parts[1] ?? '')|split(':')|slice(0,2)|join(':') %}
                  <span class="session-dur">—</span>
                  <span class="session-hour">{{ end_time_str }}</span>
                {% elseif session.duration_minutes is defined and session.duration_minutes %}
                  {% set dur = session.duration_minutes %}
                  <span class="session-dur">{{ dur >= 60 ? (dur // 60) ~ ' hr' : dur ~ ' min' }}</span>
                {% endif %}
              {% endif %}
            </div>

            {# Main content #}
            <div class="session-main">
              <div class="session-tags">
                {% if session.session_type %}
                  <span class="tag tag-{{ type_tone }}">{{ session.session_type }}</span>
                {% endif %}
                {% if is_enrolled %}
                  <span class="tag tag-ok">{{ 'enrolled'|t }}</span>
                {% endif %}
              </div>

              {% if session.description %}
                <h3 title="{{ session.description }}">{{ session.title }}</h3>
                <p class="session-desc">{{ session.description|slice(0, 120) }}{% if session.description|length > 120 %}…{% endif %}</p>
              {% else %}
                <h3>{{ session.title }}</h3>
              {% endif %}

              <div class="session-foot">
                {% if speaker_name %}
                  <span>
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {{ speaker_name }}
                  </span>
                {% endif %}
                {% if session.location %}
                  <span>
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {{ session.location }}
                  </span>
                {% endif %}
                <span>
                  {% if session.price is defined and session.price is not null and session.price != '' and session.price > 0 %}
                    € {{ session.price }}
                  {% else %}
                    {{ 'Free'|t }}
                  {% endif %}
                </span>
              </div>
            </div>

            {# Side: capacity + inschrijven knop #}
            <div class="session-side">
              {% if session.max_attendees > 0 %}
                <div class="capacity">
                  <div class="capacity-bar">
                    <div class="capacity-fill {{ cap_class }}" style="width:{{ pct }}%"></div>
                  </div>
                  <div class="capacity-meta">
                    <span>{{ session.current_attendees }}&thinsp;/&thinsp;{{ session.max_attendees }}</span>
                    <span class="capacity-pct">{{ pct }}%{{ pct >= 95 ? ' full' : '' }}</span>
                  </div>
                </div>
              {% endif %}

              {% if is_enrolled %}
                <span class="tag tag-ok" style="justify-content:center;">{{ 'Ingeschreven'|t }}</span>
                <a href="/sessions/unenroll/{{ sid }}?destination=/sessions/enroll"
                   class="btn btn-ghost btn-sm btn-full"
                   style="text-align:center;display:block;text-decoration:none;"
                   onclick="return confirm('{{ 'Weet je zeker dat je deze sessie wil laten vallen?'|t|e('js') }}')">
                  {{ 'Uitschrijven'|t }}
                </a>
              {% elseif is_full %}
                <span class="btn btn-primary btn-sm btn-full" style="text-align:center;cursor:not-allowed;opacity:.55;">
                  {{ 'Vol'|t }}
                </span>
              {% else %}
                <a href="/sessions/enroll-single/{{ sid }}"
                   class="btn btn-primary btn-sm btn-full"
                   style="text-align:center;display:block;text-decoration:none;">
                  {{ 'Inschrijven'|t }}
                </a>
              {% endif %}
            </div>

          </article>
        {% endfor %}
            </div>{# /.session-list #}
          </section>
        {% endfor %}
      </div>{# /.schedule-stack #}

    {% endif %}

    {# ── Submit ── #}
    <div class="sessions-submit-row">
      {{ form.submit }}
    </div>

  </form>
</div>

{# ── Session detail modal ── #}
<div id="sdmodal" class="sdmodal" hidden aria-modal="true" role="dialog" aria-labelledby="sdmodal-title">
  <div class="sdmodal-backdrop"></div>
  <div class="sdmodal-box">
    <div class="sdmodal-header">
      <div style="flex:1;min-width:0;">
        <div id="sdmodal-tags" style="margin-bottom:8px;display:flex;gap:6px;flex-wrap:wrap;"></div>
        <h2 id="sdmodal-title" style="margin:0;font-size:20px;font-weight:700;letter-spacing:-.02em;line-height:1.2;"></h2>
      </div>
      <button type="button" id="sdmodal-close" class="sdmodal-close" aria-label="{{ 'Sluiten'|t }}">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="sdmodal-body">
      <div id="sdmodal-meta" class="sdmodal-meta"></div>
      <div id="sdmodal-description" class="sdmodal-description"></div>
      <div id="sdmodal-capacity" class="sdmodal-capacity-wrap"></div>
      <div id="sdmodal-footer" class="sdmodal-footer"></div>
    </div>
  </div>
</div>

<script>
(function() {
  /* ── Filter & search ── */
  var search  = document.getElementById('session-search');
  var chipRow = document.getElementById('chip-row');
  var cards   = document.querySelectorAll('.session-card');
  var activeFilter = 'all';

  function filterCards() {
    var q = search ? search.value.toLowerCase() : '';
    cards.forEach(function(card) {
      var type    = (card.dataset.type    || '').toLowerCase();
      var title   = (card.dataset.title   || '').toLowerCase();
      var speaker = (card.dataset.speaker || '').toLowerCase();
      var loc     = (card.dataset.location|| '').toLowerCase();
      var matchFilter = activeFilter === 'all' || type === activeFilter;
      var matchSearch = !q || title.indexOf(q) > -1 || speaker.indexOf(q) > -1 || loc.indexOf(q) > -1;
      card.style.display = (matchFilter && matchSearch) ? '' : 'none';
    });
    document.querySelectorAll('.schedule-day').forEach(function(section) {
      var anyVisible = Array.from(section.querySelectorAll('.session-card')).some(function(c) {
        return c.style.display !== 'none';
      });
      section.style.display = anyVisible ? '' : 'none';
    });
  }

  if (search) search.addEventListener('input', filterCards);

  if (chipRow) {
    chipRow.addEventListener('click', function(e) {
      var btn = e.target.closest('.chip');
      if (!btn) return;
      chipRow.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('is-on'); });
      btn.classList.add('is-on');
      activeFilter = btn.dataset.filter;
      filterCards();
    });
  }

  /* ── Session detail modal ── */
  var modal    = document.getElementById('sdmodal');
  var backdrop = modal.querySelector('.sdmodal-backdrop');
  var closeBtn = document.getElementById('sdmodal-close');

  var TONE = { keynote: 'primary', workshop: 'accent', reception: 'warm' };

  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

  function openModal(data) {
    /* Tags row */
    var tagsEl = document.getElementById('sdmodal-tags');
    tagsEl.innerHTML = '';
    if (data.type) {
      var tone = TONE[data.type] || 'neutral';
      tagsEl.innerHTML += '<span class="tag tag-' + tone + '">' + esc(data.type) + '</span>';
    }
    if (data.enrolled) tagsEl.innerHTML += '<span class="tag tag-ok">{{ "ingeschreven"|t }}</span>';
    if (data.full)     tagsEl.innerHTML += '<span class="tag tag-hot">{{ "vol"|t }}</span>';

    /* Title */
    document.getElementById('sdmodal-title').textContent = data.title || '';

    /* Meta row: date, time, location, speaker */
    var meta = '';
    if (data.date || data.time) {
      meta += '<div class="sdmodal-meta-item">'
            + '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 2v4M8 2v4M3 10h18"/></svg>'
            + '<span>' + esc(data.date) + (data.time ? ' · ' + esc(data.time) : '') + (data.duration ? ' · ' + (data.duration >= 60 ? Math.floor(data.duration/60) + ' hr' : data.duration + ' min') : '') + '</span>'
            + '</div>';
    }
    if (data.location) {
      meta += '<div class="sdmodal-meta-item">'
            + '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>'
            + '<span>' + esc(data.location) + '</span>'
            + '</div>';
    }
    if (data.speaker) {
      var spk = esc(data.speaker);
      if (data.speaker_org) spk += ' <span style="color:var(--muted)">· ' + esc(data.speaker_org) + '</span>';
      if (data.speaker_email) spk += ' <a href="mailto:' + esc(data.speaker_email) + '" style="color:var(--primary);font-size:12px;margin-left:4px;">' + esc(data.speaker_email) + '</a>';
      meta += '<div class="sdmodal-meta-item">'
            + '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>'
            + '<span>' + spk + '</span>'
            + '</div>';
    }
    document.getElementById('sdmodal-meta').innerHTML = meta;

    /* Description */
    var descEl = document.getElementById('sdmodal-description');
    descEl.innerHTML = data.description
      ? '<p style="margin:0;font-size:14px;line-height:1.6;color:var(--ink);">' + esc(data.description) + '</p>'
      : '';

    /* Capacity */
    var capEl = document.getElementById('sdmodal-capacity');
    if (data.max > 0) {
      var pct  = Math.round((data.current / data.max) * 100);
      var cls  = pct >= 95 ? 'capacity-hot' : pct >= 75 ? 'capacity-warm' : 'capacity-cool';
      capEl.innerHTML =
        '<div class="sdmodal-cap-label">{{ "Capaciteit"|t }}</div>'
        + '<div class="capacity"><div class="capacity-bar"><div class="capacity-fill ' + cls + '" style="width:' + pct + '%"></div></div>'
        + '<div class="capacity-meta"><span>' + data.current + ' / ' + data.max + '</span><span class="capacity-pct">' + pct + '%</span></div></div>';
    } else {
      capEl.innerHTML = '';
    }

    /* Footer: price + enroll action */
    var footEl = document.getElementById('sdmodal-footer');
    var priceHtml = (data.price && parseFloat(data.price) > 0)
      ? '<div class="sdmodal-price">€ ' + esc(String(data.price)) + '</div>'
      : '<div class="sdmodal-price">{{ "Free"|t }}</div>';
    var enrollHtml = '';
    {% set confirm_drop_js = 'Weet je zeker dat je deze sessie wil laten vallen?'|t|e('js') %}
    if (data.enrolled) {
      enrollHtml = '<span class="tag tag-ok" style="padding:8px 16px;font-size:14px;">{{ "Ingeschreven"|t }}</span>'
        + '<a href="/sessions/unenroll/' + esc(String(data.session_id)) + '?destination=/sessions/enroll"'
        + ' class="btn btn-ghost btn-sm" style="margin-top:8px;display:inline-block;text-decoration:none;"'
        + ' onclick="return confirm(\'{{ confirm_drop_js }}\')">'
        + '{{ "Uitschrijven"|t }}</a>';
    } else if (data.full) {
      enrollHtml = '<span class="btn btn-primary btn-sm" style="cursor:not-allowed;opacity:.55;text-decoration:none;">{{ "Vol"|t }}</span>';
    } else if (data.session_id) {
      enrollHtml = '<a href="/sessions/enroll-single/' + esc(String(data.session_id)) + '" class="btn btn-primary btn-sm" style="text-decoration:none;">{{ "Inschrijven"|t }}</a>';
    }
    footEl.innerHTML = priceHtml + enrollHtml;

    modal.hidden = false;
    modal.dataset.currentSid = data.sid || '';
    document.body.classList.add('modal-open');
    document.getElementById('sdmodal-close').focus();

    /* Enroll button handler */
    var enrollBtn = document.getElementById('sdmodal-enroll-btn');
    if (enrollBtn) {
      enrollBtn.onclick = function() {
        var sid = modal.dataset.currentSid;
        var cb = document.querySelector('input[name="session_ids[' + sid + ']"]');
        if (cb) { cb.checked = true; }
        closeModal();
        /* Scroll to submit button */
        var submitRow = document.querySelector('.sessions-submit-row');
        if (submitRow) submitRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
      };
    }
  }

  function closeModal() {
    modal.hidden = true;
    document.body.classList.remove('modal-open');
  }

  /* Delegated click on session cards — skip form controls */
  document.addEventListener('click', function(e) {
    if (!modal.hidden && e.target.closest('#sdmodal')) return; /* inside modal */
    var card = e.target.closest('.session-card[data-session]');
    if (!card) return;
    /* Ignore clicks on form elements so checkbox still works */
    if (e.target.closest('input, label, button, a, .session-checkbox-wrap')) return;
    try {
      var data = JSON.parse(card.dataset.session);
      openModal(data);
    } catch(err) {}
  });

  /* Keyboard: Enter/Space on card */
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    var card = e.target.closest('.session-card[data-session]');
    if (!card) return;
    if (e.target.closest('input, label, button, a')) return;
    e.preventDefault();
    try {
      var data = JSON.parse(card.dataset.session);
      openModal(data);
    } catch(err) {}
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });
}());

/* ── Scroll to feedback on load ── */
(function () {
  var msgs = document.querySelector('#enrollment-success, #enrollment-error, .messages, .alert-error');
  if (msgs) {
    msgs.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
}());
</script>

