{#
  form--session-enrollment-form.html.twig
  Session enrollment form styled with Tailwind + CSS variables.
  Maps to form ID: session_enrollment_form
#}

<div class="card p-8 max-w-xl mx-auto">

  <div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight" style="color:var(--color-text);">
      {{ 'Enroll in sessions'|t }}
    </h1>
    <p class="mt-1 text-sm" style="color:var(--color-muted);">
      {{ 'Select one or more sessions you want to attend.'|t }}
    </p>
  </div>

  {% if message %}
    <div class="mb-6">{{ message }}</div>
  {% endif %}

  <form{{ attributes }}>
    {{ form.form_build_id }}
    {{ form.form_token }}
    {{ form.form_id }}

    {% if form.notice %}
      <div class="msg-warning mb-6">{{ form.notice }}</div>
    {% endif %}

    {% if form.session_ids %}
      <div class="mb-6">
        <p class="section-label">{{ 'Available sessions'|t }}</p>
        {{ form.session_ids }}
      </div>
    {% endif %}

    {% if form.submit %}
      <div>{{ form.submit }}</div>
    {% endif %}
  </form>

</div>
