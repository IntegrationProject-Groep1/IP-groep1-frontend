{#
  form--user-login-form.html.twig
  Rendert alleen het formulier; de auth-wrap layout staat in page.html.twig.
#}

{% if message %}
  <div style="margin-bottom:16px;">{{ message }}</div>
{% endif %}

<a href="/auth/microsoft" class="btn-microsoft">
  <svg width="20" height="20" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
    <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
    <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
    <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
  </svg>
  {{ 'Continue with Microsoft'|t }}
</a>

<div class="oauth-divider"><span>{{ 'or'|t }}</span></div>

<form{{ attributes.addClass('form-grid') }}>
  {{ children }}
</form>
