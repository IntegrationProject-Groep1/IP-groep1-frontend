{#
  form--user-login-form.html.twig
  Shift Festival 2026 login form met auth-wrap layout.
#}

<div class="auth-wrap">

  {# ── Dark sidebar ── #}
  <aside class="auth-side">
    <div class="auth-side-top">
      <a href="{{ path('<front>') }}" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="24" height="24" rx="7" fill="white"/>
          <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--ink)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
        </svg>
        <span style="font-weight:700;font-size:16px;color:white;">Shift Festival</span>
      </a>
    </div>

    <div class="auth-side-body">
      <h2>{{ 'Welkom terug.'|t }}</h2>
      <p>{{ 'Log in om je badge te bekijken, het programma te verkennen en je sessies te beheren.'|t }}</p>
      <ul>
        <li>{{ 'Je QR-badge is altijd een tik verwijderd'|t }}</li>
        <li>{{ 'Schrijf je in of meld je af voor sessies in real time'|t }}</li>
        <li>{{ 'Wallet-saldo gesynchroniseerd met de kassa'|t }}</li>
      </ul>
    </div>

    <div class="auth-side-foot">
      <div class="badge-mini">
        <div class="badge-mini-top">
          <span>SHIFT · 2026</span>
          <span>12 – 14 MEI</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" style="background:white;padding:4px;border-radius:6px;" aria-hidden="true">
            <rect width="56" height="56" fill="white"/>
            <rect x="4" y="4" width="14" height="14" rx="2" fill="var(--ink)"/>
            <rect x="6" y="6" width="10" height="10" rx="1" fill="white"/>
            <rect x="8" y="8" width="6" height="6" fill="var(--ink)"/>
            <rect x="38" y="4" width="14" height="14" rx="2" fill="var(--ink)"/>
            <rect x="40" y="6" width="10" height="10" rx="1" fill="white"/>
            <rect x="42" y="8" width="6" height="6" fill="var(--ink)"/>
            <rect x="4" y="38" width="14" height="14" rx="2" fill="var(--ink)"/>
            <rect x="6" y="40" width="10" height="10" rx="1" fill="white"/>
            <rect x="8" y="42" width="6" height="6" fill="var(--ink)"/>
            <rect x="22" y="4" width="4" height="4" fill="var(--ink)"/>
            <rect x="28" y="4" width="4" height="4" fill="var(--ink)"/>
            <rect x="22" y="10" width="4" height="4" fill="var(--ink)"/>
            <rect x="28" y="10" width="4" height="4" fill="var(--ink)"/>
            <rect x="4" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="4" y="28" width="4" height="4" fill="var(--ink)"/>
            <rect x="22" y="22" width="4" height="4" fill="var(--accent)"/>
            <rect x="28" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="34" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="22" y="28" width="4" height="4" fill="var(--ink)"/>
            <rect x="34" y="28" width="4" height="4" fill="var(--ink)"/>
            <rect x="38" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="44" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="48" y="22" width="4" height="4" fill="var(--ink)"/>
            <rect x="38" y="28" width="4" height="4" fill="var(--ink)"/>
            <rect x="48" y="28" width="4" height="4" fill="var(--ink)"/>
            <rect x="22" y="38" width="4" height="4" fill="var(--ink)"/>
            <rect x="28" y="38" width="4" height="4" fill="var(--ink)"/>
            <rect x="22" y="44" width="4" height="4" fill="var(--ink)"/>
            <rect x="28" y="44" width="4" height="4" fill="var(--ink)"/>
            <rect x="34" y="44" width="4" height="4" fill="var(--ink)"/>
            <rect x="38" y="38" width="4" height="4" fill="var(--ink)"/>
            <rect x="44" y="38" width="4" height="4" fill="var(--ink)"/>
            <rect x="44" y="44" width="4" height="4" fill="var(--ink)"/>
            <rect x="48" y="38" width="4" height="4" fill="var(--ink)"/>
          </svg>
          <div>
            <div class="badge-mini-name">Festival Badge</div>
            <div class="badge-mini-role">Deelnemer 2026</div>
          </div>
        </div>
      </div>
    </div>
  </aside>

  {# ── Form pane ── #}
  <main class="auth-form-pane">
    <div class="auth-form-inner">
      <a href="{{ path('<front>') }}" class="auth-back">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        {{ 'Terug'|t }}
      </a>

      <h1>{{ 'Inloggen'|t }}</h1>
      <p class="auth-form-sub">
        {{ 'Nog geen account?'|t }}
        <a href="{{ path('user.register') }}">{{ 'Maak er hier een aan'|t }}</a>.
      </p>

      {% if message %}
        <div style="margin-bottom:20px;">{{ message }}</div>
      {% endif %}

      <form{{ attributes }} class="form-grid">
        {{ form.form_build_id }}
        {{ form.form_token }}
        {{ form.form_id }}

        <div>{{ form.name }}</div>
        <div>{{ form.pass }}</div>

        <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;">
          {{ form.remember_me is defined ? form.remember_me : '' }}
          <a href="{{ path('user.pass') }}" style="color:var(--muted);">{{ 'Wachtwoord vergeten?'|t }}</a>
        </div>

        <div>{{ form.actions }}</div>

        {{ form|without('name', 'pass', 'actions', 'remember_me', 'form_build_id', 'form_token', 'form_id') }}
      </form>

    </div>
  </main>

</div>
