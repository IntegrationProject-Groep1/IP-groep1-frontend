{#
  page--front.html.twig — Shift Festival 2026 landing page.
  Variables: hero_enabled, hero_title, hero_subtitle, hero_cta_label, hero_cta_url,
             site_name, nav_show_register, nav_show_enroll, footer_text,
             social_*, logged_in, is_admin, is_company_user, current_first_name,
             current_uid, wallet_balance, logo.
#}

<div class="landing">

  {# ════════════════════════════════════════ NAV #}
  <header>
    <nav class="landing-nav">
      <a href="{{ path('<front>') }}" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="24" height="24" rx="7" fill="var(--ink)"/>
          <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--bg)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
        </svg>
        <span style="font-weight:700;font-size:16px;color:var(--ink);">{{ site_name }}</span>
      </a>

      <div class="landing-nav-links">
        <a href="#program">{{ 'Programma'|t }}</a>
        <a href="#venue">{{ 'Locatie'|t }}</a>
        <a href="#info">{{ 'Info'|t }}</a>
      </div>

      <div class="landing-nav-cta landing-nav-cta--desktop">
        {% if logged_in %}
          {% if nav_show_enroll and enroll_url %}
            <a href="{{ enroll_url }}"
               style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:1px solid var(--line-2);border-radius:10px;font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;">
              {{ 'Sessies bekijken'|t }}
            </a>
          {% endif %}
          {% if qr_url %}
            <a href="{{ qr_url }}"
               style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--ink);color:white;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;">
              {{ 'Mijn badge'|t }}
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          {% endif %}
        {% else %}
          <a href="{{ path('user.login') }}"
             style="display:inline-flex;align-items:center;padding:8px 16px;border:1px solid var(--line-2);border-radius:10px;font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;">
            {{ 'Inloggen'|t }}
          </a>
          {% if nav_show_register and register_url %}
            <a href="{{ register_url }}"
               style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--ink);color:white;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;">
              {{ 'Badge aanvragen'|t }}
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          {% endif %}
        {% endif %}
      </div>
      {# Hamburger — visible on mobile only #}
      <button id="landing-menu-toggle" class="landing-hamburger"
              aria-label="{{ 'Menu'|t }}" aria-expanded="false"
              aria-controls="landing-mobile-menu">
        <svg id="landing-icon-open" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="landing-icon-close" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>

    {# Mobile menu panel #}
    <div id="landing-mobile-menu" class="landing-mobile-menu" aria-hidden="true">
      <a href="#program" class="landing-mobile-link">{{ 'Programma'|t }}</a>
      <a href="#venue" class="landing-mobile-link">{{ 'Locatie'|t }}</a>
      <a href="#info" class="landing-mobile-link">{{ 'Info'|t }}</a>
      <hr class="landing-mobile-divider">
      {% if logged_in %}
        {% if nav_show_enroll and enroll_url %}
          <a href="{{ enroll_url }}" class="landing-mobile-link">{{ 'Sessies bekijken'|t }}</a>
        {% endif %}
        {% if qr_url %}
          <a href="{{ qr_url }}" class="landing-mobile-cta">{{ 'Mijn badge'|t }}</a>
        {% endif %}
      {% else %}
        <a href="{{ path('user.login') }}" class="landing-mobile-link">{{ 'Inloggen'|t }}</a>
        {% if nav_show_register and register_url %}
          <a href="{{ register_url }}" class="landing-mobile-cta">{{ 'Badge aanvragen'|t }}</a>
        {% endif %}
      {% endif %}
    </div>
  </header>

  {# ════════════════════════════════════════ HERO #}
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-lhs">
        <div class="hero-eyebrow">
          <span class="hero-dot"></span>
          {{ 'Registratie is open'|t }}
        </div>
        <h1 class="hero-title">
          {% if hero_enabled and hero_title %}
            <span class="hero-line">{{ hero_title }}</span>
          {% else %}
            <span class="hero-line">{{ 'Drie dagen.'|t }}</span>
            <span class="hero-line">{{ 'Twaalf podia.'|t }}</span>
            <span class="hero-line hero-line-accent">{{ 'Één geïntegreerde ervaring.'|t }}</span>
          {% endif %}
        </h1>
        {% if hero_subtitle %}
          <p class="hero-sub">{{ hero_subtitle }}</p>
        {% else %}
          <p class="hero-sub">{{ 'Het festival waar technologie, creativiteit en samenwerking samenkomen. Schrijf je in voor sessies, scan je badge en ontdek het programma.'|t }}</p>
        {% endif %}

        <div class="hero-meta">
          <div>
            <span class="hero-meta-k">{{ 'Wanneer'|t }}</span>
            <span class="hero-meta-v">{{ 'Mei 2026'|t }}</span>
          </div>
          <div>
            <span class="hero-meta-k">{{ 'Locatie'|t }}</span>
            <span class="hero-meta-v">{{ 'Desiderius Campus'|t }}</span>
          </div>
          <div>
            <span class="hero-meta-k">{{ 'Sessies'|t }}</span>
            <span class="hero-meta-v">{{ '12 podia · 84 sessies'|t }}</span>
          </div>
        </div>

        <div class="hero-ctas">
          {% if logged_in %}
            {% if nav_show_enroll and enroll_url %}
              <a href="{{ enroll_url }}"
                 style="display:inline-flex;align-items:center;gap:8px;padding:13px 22px;background:var(--ink);color:white;border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">
                {{ 'Sessies inschrijven'|t }}
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            {% endif %}
            {% if qr_url %}
              <a href="{{ qr_url }}"
                 style="display:inline-flex;align-items:center;gap:8px;padding:13px 22px;background:transparent;color:var(--ink);border:1px solid var(--line-2);border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">
                {{ 'Mijn badge'|t }}
              </a>
            {% endif %}
          {% else %}
            {% if nav_show_register and register_url %}
              <a href="{{ register_url }}"
                 style="display:inline-flex;align-items:center;gap:8px;padding:13px 22px;background:var(--ink);color:white;border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">
                {{ 'Registreer voor het festival'|t }}
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            {% endif %}
            <a href="{{ path('user.login') }}"
               style="display:inline-flex;align-items:center;gap:8px;padding:13px 22px;background:transparent;color:var(--ink);border:1px solid var(--line-2);border-radius:12px;font-size:15px;font-weight:600;text-decoration:none;">
              {{ 'Ik heb al een badge'|t }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="hero-rhs">
        {# Badge mockup #}
        <div class="badge-mock">
          <div class="badge-strap"></div>
          <div class="badge-clip"></div>
          <div class="badge-card">
            <div class="badge-card-top">
              <span class="badge-event">SHIFT · 2026</span>
              <span class="badge-day">DAG 01</span>
            </div>
            <div class="badge-name">{{ logged_in ? current_first_name : site_name }}</div>
            <div class="badge-role">{{ logged_in ? 'Deelnemer'|t : 'Festival Attendee'|t }}</div>
            <div class="badge-qr">
              <svg width="120" height="120" viewBox="0 0 120 120" fill="none" aria-label="{{ 'QR code voorbeeld'|t }}">
                <rect width="120" height="120" fill="white"/>
                <rect x="10" y="10" width="32" height="32" rx="3" fill="var(--ink)"/>
                <rect x="15" y="15" width="22" height="22" rx="2" fill="white"/>
                <rect x="19" y="19" width="14" height="14" fill="var(--ink)"/>
                <rect x="78" y="10" width="32" height="32" rx="3" fill="var(--ink)"/>
                <rect x="83" y="15" width="22" height="22" rx="2" fill="white"/>
                <rect x="87" y="19" width="14" height="14" fill="var(--ink)"/>
                <rect x="10" y="78" width="32" height="32" rx="3" fill="var(--ink)"/>
                <rect x="15" y="83" width="22" height="22" rx="2" fill="white"/>
                <rect x="19" y="87" width="14" height="14" fill="var(--ink)"/>
                <rect x="48" y="10" width="6" height="6" fill="var(--ink)"/>
                <rect x="56" y="10" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="10" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="18" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="18" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="26" width="6" height="6" fill="var(--ink)"/>
                <rect x="56" y="26" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="26" width="6" height="6" fill="var(--ink)"/>
                <rect x="10" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="18" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="10" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="10" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="18" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="48" width="6" height="6" fill="var(--accent)"/>
                <rect x="56" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="72" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="72" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="56" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="72" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="78" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="86" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="104" y="48" width="6" height="6" fill="var(--ink)"/>
                <rect x="78" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="94" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="104" y="56" width="6" height="6" fill="var(--ink)"/>
                <rect x="86" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="94" y="64" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="78" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="78" width="6" height="6" fill="var(--ink)"/>
                <rect x="72" y="78" width="6" height="6" fill="var(--ink)"/>
                <rect x="56" y="86" width="6" height="6" fill="var(--ink)"/>
                <rect x="72" y="86" width="6" height="6" fill="var(--ink)"/>
                <rect x="48" y="94" width="6" height="6" fill="var(--ink)"/>
                <rect x="56" y="94" width="6" height="6" fill="var(--ink)"/>
                <rect x="64" y="94" width="6" height="6" fill="var(--ink)"/>
                <rect x="78" y="78" width="6" height="6" fill="var(--ink)"/>
                <rect x="94" y="78" width="6" height="6" fill="var(--ink)"/>
                <rect x="86" y="86" width="6" height="6" fill="var(--ink)"/>
                <rect x="94" y="94" width="6" height="6" fill="var(--ink)"/>
                <rect x="104" y="86" width="6" height="6" fill="var(--ink)"/>
              </svg>
            </div>
            <div class="badge-foot">
              <span>BDG-2026</span>
              <span>Desiderius Campus</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ════════════════════════════════════════ STATS STRIP #}
  <div class="strip">
    <div class="strip-item">
      <span class="strip-num">2.400+</span>
      <span class="strip-lbl">{{ 'Verwachte deelnemers'|t }}</span>
    </div>
    <div class="strip-item">
      <span class="strip-num">84</span>
      <span class="strip-lbl">{{ 'Sessies over drie dagen'|t }}</span>
    </div>
    <div class="strip-item">
      <span class="strip-num">12</span>
      <span class="strip-lbl">{{ 'Podia en labs op campus'|t }}</span>
    </div>
    <div class="strip-item">
      <span class="strip-num">37</span>
      <span class="strip-lbl">{{ 'Partnerorganisaties'|t }}</span>
    </div>
  </div>

  {# ════════════════════════════════════════ PROGRAM / CONTENT #}
  <section class="program" id="program">
    {% if page.content %}
      {{ page.content }}
    {% else %}
      <div class="section-head">
        <span class="section-eyebrow">{{ 'Dag één · Dinsdag'|t }}</span>
        <h2>{{ 'Een festivalprogramma, geen conferentieagenda.'|t }}</h2>
        <p>{{ 'Een voorproefje van wat er op het programma staat. Na registratie kun je je inschrijven voor sessies met nog beschikbare plaatsen.'|t }}</p>
      </div>
      <div class="program-grid">
        <article class="program-card">
          <div class="program-card-top">
            <span class="tag tag-primary">{{ 'keynote'|t }}</span>
            <span class="program-card-time">09:00</span>
          </div>
          <h3>{{ 'Integratie in de praktijk'|t }}</h3>
          <p>{{ 'Hoe systemen met elkaar communiceren in een moderne digitale omgeving — van API-design tot event-driven architectuur.'|t }}</p>
          <div class="program-card-foot">
            <span>Hoofdpodium</span>
          </div>
        </article>
        <article class="program-card">
          <div class="program-card-top">
            <span class="tag tag-accent">{{ 'workshop'|t }}</span>
            <span class="program-card-time">10:30</span>
          </div>
          <h3>{{ 'Hands-on: message brokers'|t }}</h3>
          <p>{{ 'Aan de slag met RabbitMQ en Kafka. Leer hoe je betrouwbaar berichten verstuurt en verwerkt in gedistribueerde systemen.'|t }}</p>
          <div class="program-card-foot">
            <span>Lab A</span>
          </div>
        </article>
        <article class="program-card">
          <div class="program-card-top">
            <span class="tag">{{ 'talk'|t }}</span>
            <span class="program-card-time">13:00</span>
          </div>
          <h3>{{ 'Digitale badges & identiteit'|t }}</h3>
          <p>{{ 'QR-codes, wallets en check-in systemen: hoe het festival zijn eigen backend in productie heeft gebracht.'|t }}</p>
          <div class="program-card-foot">
            <span>Studio B</span>
          </div>
        </article>
        <article class="program-card">
          <div class="program-card-top">
            <span class="tag tag-ok">{{ 'panel'|t }}</span>
            <span class="program-card-time">15:00</span>
          </div>
          <h3>{{ 'Toekomst van samenwerking'|t }}</h3>
          <p>{{ 'Vijf experts bespreken hoe teams de integratie van technologie en organisatie aanpakken in 2026 en daarna.'|t }}</p>
          <div class="program-card-foot">
            <span>Auditorium</span>
          </div>
        </article>
      </div>
    {% endif %}
  </section>

  {# ════════════════════════════════════════ FOOTER #}
  <footer class="landing-foot" id="venue">
    <div style="display:inline-flex;align-items:center;gap:10px;">
      <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="24" height="24" rx="7" fill="var(--ink)"/>
        <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--bg)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
      </svg>
      <span style="font-weight:700;font-size:14px;color:var(--ink);">{{ site_name }} 2026</span>
    </div>
    <div class="landing-foot-meta">
      {% if footer_text %}
        {{ footer_text }}
      {% else %}
        <span>Desiderius Campus</span>
        <span class="dot-sep">·</span>
        <span>{{ 'Mei 2026'|t }}</span>
        <span class="dot-sep">·</span>
        <span>{{ 'Een integratieproject van Desideriushogeschool'|t }}</span>
      {% endif %}
    </div>
  </footer>

</div>{# end .landing #}
