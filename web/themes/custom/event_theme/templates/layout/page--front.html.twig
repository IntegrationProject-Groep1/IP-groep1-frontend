{#
  page--front.html.twig — Front page layout with configurable hero section.
  Variables injected by event_theme_preprocess_page__front():
    hero_enabled, hero_title, hero_subtitle, hero_cta_label, hero_cta_url,
    plus all variables from event_theme_preprocess_page().
#}

{# ════════════════════════════════════════════════════════════ HEADER #}
<header style="background-color:var(--color-nav-bg);" class="shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href="{{ path('<front>') }}"
         class="flex items-center gap-2.5 font-bold text-lg no-underline hover:opacity-80 transition-opacity"
         style="color:var(--color-primary);">
        {% if logo %}
          <img src="{{ logo }}" alt="{{ site_name }}" class="h-9 w-auto">
        {% else %}
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-full text-white text-sm font-bold"
                style="background-color:var(--color-primary);">
            {{ site_name|slice(0,1)|upper }}
          </span>
        {% endif %}
        <span>{{ site_name }}</span>
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="{{ 'Main navigation'|t }}">
        <a href="{{ path('<front>') }}" class="nav-link is-active">{{ 'Home'|t }}</a>
        {% if not logged_in and nav_show_register %}
          <a href="{{ path('registration_form.register') }}" class="nav-link">{{ 'Register'|t }}</a>
        {% endif %}
        {% if logged_in and nav_show_enroll %}
          <a href="{{ path('session_enrollment.enroll') }}" class="nav-link">{{ 'Enroll'|t }}</a>
        {% endif %}
        {% if is_admin %}
          <a href="{{ path('session_management.create') }}" class="nav-link">{{ 'Create session'|t }}</a>
          <a href="{{ path('session_management.end') }}" class="nav-link">{{ 'End session'|t }}</a>
        {% endif %}
        {% if logged_in %}
          <a href="{{ path('user.logout') }}" class="btn-primary ml-2">{{ 'Log out'|t }}</a>
        {% else %}
          <a href="{{ path('user.login') }}" class="btn-primary ml-2">{{ 'Log in'|t }}</a>
        {% endif %}
      </nav>

      <button id="menu-toggle"
              class="md:hidden p-2 rounded-lg transition-colors"
              style="color:var(--color-muted);"
              aria-label="{{ 'Toggle menu'|t }}"
              aria-expanded="false"
              aria-controls="mobile-menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu"
       class="md:hidden hidden border-t"
       style="background-color:var(--color-nav-bg);border-color:var(--color-border);">
    <nav class="px-4 pt-2 pb-4 flex flex-col gap-1">
      <a href="{{ path('<front>') }}" class="nav-link is-active">{{ 'Home'|t }}</a>
      {% if not logged_in and nav_show_register %}
        <a href="{{ path('registration_form.register') }}" class="nav-link">{{ 'Register'|t }}</a>
      {% endif %}
      {% if logged_in and nav_show_enroll %}
        <a href="{{ path('session_enrollment.enroll') }}" class="nav-link">{{ 'Enroll'|t }}</a>
      {% endif %}
      {% if is_admin %}
        <a href="{{ path('session_management.create') }}" class="nav-link">{{ 'Create session'|t }}</a>
        <a href="{{ path('session_management.end') }}" class="nav-link">{{ 'End session'|t }}</a>
      {% endif %}
      {% if logged_in %}
        <a href="{{ path('user.logout') }}" class="btn-primary mt-2 text-center">{{ 'Log out'|t }}</a>
      {% else %}
        <a href="{{ path('user.login') }}" class="btn-primary mt-2 text-center">{{ 'Log in'|t }}</a>
      {% endif %}
    </nav>
  </div>
</header>

{# ════════════════════════════════════════════════════════════ HERO #}
{% if hero_enabled %}
  <section class="relative overflow-hidden py-24 sm:py-32" style="background-color:var(--color-hero-bg);">
    {# Decorative circles #}
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-32 w-96 h-96 rounded-full opacity-10 bg-white"></div>
      <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full opacity-10 bg-white"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6">
        {{ hero_title }}
      </h1>
      {% if hero_subtitle %}
        <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10">
          {{ hero_subtitle }}
        </p>
      {% endif %}
      {% if hero_cta_label and hero_cta_url %}
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          {% if not logged_in %}
            <a href="{{ hero_cta_url }}"
               class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-white font-semibold text-sm transition-all hover:bg-white/90 no-underline shadow-lg"
               style="color:var(--color-hero-bg);">
              {{ hero_cta_label }}
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          {% endif %}
          {% if logged_in and nav_show_enroll %}
            <a href="{{ path('session_enrollment.enroll') }}"
               class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-white font-semibold text-sm transition-all hover:bg-white/90 no-underline shadow-lg"
               style="color:var(--color-hero-bg);">
              {{ 'Enroll in sessions'|t }}
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          {% endif %}
          {% if is_admin %}
            <a href="{{ path('session_management.create') }}"
               class="inline-flex items-center justify-center px-8 py-3.5 rounded-full font-semibold text-sm text-white border-2 border-white/50 hover:border-white transition-colors no-underline">
              {{ 'Create session'|t }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

{# ════════════════════════════════════════════════════════════ MAIN #}
<main role="main" class="flex-1 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {{ page.content }}
  </div>
</main>

{# ════════════════════════════════════════════════════════════ FOOTER #}
<footer class="mt-auto border-t" style="background-color:var(--color-surface);border-color:var(--color-border);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <p class="text-sm" style="color:var(--color-muted);">{{ footer_text }}</p>

      {% if social_facebook or social_instagram or social_linkedin or social_twitter %}
        <div class="flex items-center gap-3">
          {% if social_facebook %}
            <a href="{{ social_facebook }}" target="_blank" rel="noopener noreferrer"
               class="transition-colors hover:opacity-70" style="color:var(--color-muted);" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {% endif %}
          {% if social_instagram %}
            <a href="{{ social_instagram }}" target="_blank" rel="noopener noreferrer"
               class="transition-colors hover:opacity-70" style="color:var(--color-muted);" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          {% endif %}
          {% if social_linkedin %}
            <a href="{{ social_linkedin }}" target="_blank" rel="noopener noreferrer"
               class="transition-colors hover:opacity-70" style="color:var(--color-muted);" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          {% endif %}
          {% if social_twitter %}
            <a href="{{ social_twitter }}" target="_blank" rel="noopener noreferrer"
               class="transition-colors hover:opacity-70" style="color:var(--color-muted);" aria-label="X / Twitter">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
</footer>
