      </div>
    </div>
  </section>

  {# ── Stats strip ── #}
  <div class="strip">
    <div class="strip-item"><span class="strip-num">2.400+</span><span class="strip-lbl">{{ 'Verwachte deelnemers'|t }}</span></div>
    <div class="strip-item"><span class="strip-num">84</span><span class="strip-lbl">{{ 'Sessies over drie dagen'|t }}</span></div>
    <div class="strip-item"><span class="strip-num">12</span><span class="strip-lbl">{{ 'Podia en labs op campus'|t }}</span></div>
    <div class="strip-item"><span class="strip-num">37</span><span class="strip-lbl">{{ 'Partnerorganisaties'|t }}</span></div>
  </div>

  {# ── Program ── #}
  <section class="program" id="program">
    <div class="section-head">
      <span class="section-eyebrow">{{ 'Dag één · Dinsdag'|t }}</span>
      <h2>{{ 'Een eventprogramma, geen conferentieagenda.'|t }}</h2>
      <p>{{ 'Een voorproefje van wat er op het programma staat. Na registratie kun je je inschrijven voor sessies met nog beschikbare plaatsen.'|t }}</p>
    </div>
    <div class="program-grid">
      {% if front_sessions is not empty %}
        {% for session in front_sessions|slice(0, 4) %}
          {% set stype = session.session_type|default('talk') %}
          <article class="program-card">
            <div class="program-card-top">
              {% if stype == 'keynote' %}<span class="tag tag-primary">{{ stype }}</span>
              {% elseif stype == 'workshop' %}<span class="tag tag-accent">{{ stype }}</span>
              {% elseif stype == 'panel' %}<span class="tag tag-ok">{{ stype }}</span>
              {% else %}<span class="tag">{{ stype }}</span>
              {% endif %}
              {% if session.start_datetime %}<span class="program-card-time">{{ session.start_datetime|date('H:i') }}</span>{% endif %}
            </div>
            <h3>{{ session.title }}</h3>
            {% if session.speaker.first_name is defined %}
              <p>{{ session.speaker.first_name }} {{ session.speaker.last_name }}{% if session.speaker.organisation %} · {{ session.speaker.organisation }}{% endif %}</p>
            {% endif %}
            <div class="program-card-foot">
              <span>{{ session.location|default('') }}</span>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <article class="program-card">
          <div class="program-card-top"><span class="tag tag-primary">keynote</span><span class="program-card-time">09:30</span></div>
          <h3>{{ 'Opening Keynote — The Decade of Integration'|t }}</h3>
          <p>{{ 'Hoe systemen met elkaar communiceren in een moderne digitale omgeving — van API-design tot event-driven architectuur.'|t }}</p>
          <div class="program-card-foot"><span>{{ 'Auditorium A'|t }}</span><span class="dot-sep">·</span><span>Inez Vandenbroucke</span></div>
        </article>
        <article class="program-card">
          <div class="program-card-top"><span class="tag tag-accent">workshop</span><span class="program-card-time">11:00</span></div>
          <h3>{{ 'XSD-first contracts in practice'|t }}</h3>
          <p>{{ 'Aan de slag met RabbitMQ en Kafka. Betrouwbaar berichten versturen in gedistribueerde systemen.'|t }}</p>
          <div class="program-card-foot"><span>{{ 'Lab Room 4'|t }}</span><span class="dot-sep">·</span><span>Charles Wong</span></div>
        </article>
        <article class="program-card">
          <div class="program-card-top"><span class="tag">talk</span><span class="program-card-time">14:00</span></div>
          <h3>{{ 'Digitale badges & identiteit'|t }}</h3>
          <p>{{ 'QR-codes, wallets en check-in systemen: hoe het event zijn eigen backend in productie heeft gebracht.'|t }}</p>
          <div class="program-card-foot"><span>{{ 'Studio B'|t }}</span></div>
        </article>
        <article class="program-card">
          <div class="program-card-top"><span class="tag tag-warm">reception</span><span class="program-card-time">19:00</span></div>
          <h3>{{ 'Welcome Reception'|t }}</h3>
          <p>{{ 'Vijf experts bespreken hoe teams de integratie van technologie en organisatie aanpakken in 2026 en daarna.'|t }}</p>
          <div class="program-card-foot"><span>{{ 'Atrium · Glass Pavilion'|t }}</span></div>
        </article>
      {% endif %}
    </div>
  </section>

  {# ── Footer ── #}
  <footer class="landing-foot" id="venue">
    <div style="display:inline-flex;align-items:center;gap:8px;">
      <svg width="20" height="20" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="24" height="24" rx="7" fill="var(--ink)"/>
        <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--bg)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
      </svg>
      <span class="brand-name">{{ site_name }} 2026</span>
    </div>
    <div class="landing-foot-meta">
      <span>{{ 'Desiderius Campus · Brussel'|t }}</span>
      <span class="dot-sep">·</span>
      <span>{{ '12 – 14 mei 2026'|t }}</span>
      <span class="dot-sep">·</span>
      <span>{{ 'Een integratieproject van Desideriushogeschool'|t }}</span>
    </div>
  </footer>

</div>{# /landing #}

{% endif %}

{# ── Hidden Drupal messages → toast renderer ── #}
<div id="drupal-messages" style="display:none;" aria-hidden="true">
  {% for type, messages in toast_messages %}
    {% for message in messages %}
      <div class="messages messages--{{ type }}">
        <ul class="messages__list"><li class="messages__item">{{ message }}</li></ul>
      </div>
    {% endfor %}
  {% endfor %}
</div>
<script>
(function () {
  var svgCheck = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
  var svgWarn  = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
  var svgError = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';

  function showToast(text, type) {
    var el = document.createElement('div');
    el.className = 'toast' + (type === 'error' ? ' toast-error' : type === 'warning' ? ' toast-error' : ' toast-success');
    var icon = type === 'error' || type === 'warning' ? (type === 'warning' ? svgWarn : svgError) : svgCheck;
    el.innerHTML = icon + '<span>' + text + '</span>';
    document.body.appendChild(el);
    var offset = 24;
    document.querySelectorAll('.toast').forEach(function (t) {
      if (t !== el) offset += t.offsetHeight + 8;
    });
    el.style.top = offset + 'px';
    setTimeout(function () {
      el.style.transition = 'opacity .3s, transform .3s';
      el.style.opacity = '0';
      el.style.transform = 'translateX(12px)';
      setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 320);
    }, 4000);
  }

  document.addEventListener('DOMContentLoaded', function () {
    var container = document.getElementById('drupal-messages');
    if (!container) return;
    container.querySelectorAll('.messages').forEach(function (block) {
      var type = block.classList.contains('messages--error') ? 'error'
               : block.classList.contains('messages--warning') ? 'warning'
               : 'success';
      var items = block.querySelectorAll('.messages__item');
      if (items.length) {
        items.forEach(function (item) {
          var text = item.textContent.trim();
          if (text) showToast(text, type);
        });
      } else {
        var text = block.textContent.trim();
        if (text) showToast(text, type);
      }
    });
  });
})();
</script>
