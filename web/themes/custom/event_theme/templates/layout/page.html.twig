{#
  page.html.twig — Inner page layout with Shift Festival dark header.
  Variables: site_name, nav_show_register, nav_show_enroll, footer_text,
             social_*, current_route, logo, logged_in, wallet_balance,
             is_company_user, is_admin, current_first_name, current_uid.
#}

{# ════════════════════════════════════════════════════════════ HEADER #}
<header class="sf-header">

  {# Brand #}
  <a href="{{ path('<front>') }}" class="sf-header-brand">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" aria-hidden="true">
      <rect x="2" y="2" width="24" height="24" rx="7" fill="white"/>
      <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--ink)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
    </svg>
    <span>{{ site_name }}</span>
  </a>

  {# Desktop nav #}
  <nav class="sf-header-nav" aria-label="{{ 'Hoofdnavigatie'|t }}">
    <a href="{{ path('<front>') }}"
       class="sf-nav-link {{ is_front ? 'is-active' : '' }}">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      {{ 'Home'|t }}
    </a>
    {% if not logged_in and nav_show_register %}
      <a href="{{ path('registration_form.register') }}"
         class="sf-nav-link {{ current_route starts with 'registration_form' ? 'is-active' : '' }}">
        {{ 'Registreren'|t }}
      </a>
    {% endif %}
    {% if logged_in and nav_show_enroll %}
      <a href="{{ path('session_enrollment.enroll') }}"
         class="sf-nav-link {{ current_route starts with 'session_enrollment' ? 'is-active' : '' }}">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        {{ 'Sessies'|t }}
      </a>
    {% endif %}
    {% if logged_in and is_company_user %}
      <a href="{{ path('company_invite.invite_form') }}"
         class="sf-nav-link {{ current_route starts with 'company_invite' ? 'is-active' : '' }}">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        {{ 'Team'|t }}
      </a>
    {% endif %}
    {% if is_admin %}
      <a href="{{ path('session_management.create') }}"
         class="sf-nav-link {{ current_route == 'session_management.create' ? 'is-active' : '' }}">
        {{ 'Sessie aanmaken'|t }}
      </a>
      <a href="{{ path('session_management.end') }}"
         class="sf-nav-link {{ current_route == 'session_management.end' ? 'is-active' : '' }}">
        {{ 'Sessie beëindigen'|t }}
      </a>
    {% endif %}
  </nav>

  {# Right-side actions #}
  <div class="sf-header-actions">
    {% if logged_in %}
      {# Wallet balance badge #}
      {% if wallet_balance %}
        <a href="{{ path('qr_code.page') }}"
           style="display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid rgba(255,255,255,.15);border-radius:100px;font-size:12px;color:rgba(255,255,255,.8);text-decoration:none;">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          €{{ wallet_balance }}
        </a>
      {% endif %}

      {# QR badge button #}
      <a href="{{ path('qr_code.page') }}"
         style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border:1px solid rgba(255,255,255,.2);border-radius:8px;color:rgba(255,255,255,.7);text-decoration:none;transition:all .12s;"
         title="{{ 'Mijn QR Badge'|t }}">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4H4v8h8V4zM4 4v8M12 4v8M4 12h8M20 4h-8v8h8V4zM12 4v8M20 4v8M12 12h8M4 20h8v-8H4v8zM4 12v8M12 12v8M4 20h8"/>
        </svg>
      </a>

      {# Account dropdown #}
      <div style="position:relative;" id="sf-account-wrapper">
        <button id="sf-account-toggle" class="sf-account-btn"
                aria-haspopup="true" aria-expanded="false" aria-controls="sf-account-dropdown">
          <span class="sf-account-avatar">{{ current_first_name|slice(0,1)|upper }}</span>
          <span>{{ current_first_name }}</span>
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transition:transform .15s;" id="sf-account-chevron">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="sf-account-dropdown" class="sf-dropdown" style="display:none;" role="menu">
          <a href="{{ path('entity.user.edit_form', {'user': current_uid}) }}"
             class="sf-dropdown-item" role="menuitem">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z"/></svg>
            {{ 'Mijn gegevens'|t }}
          </a>
          <a href="{{ path('qr_code.page') }}" class="sf-dropdown-item" role="menuitem">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4H4v8h8V4zM4 4v8M12 4v8M4 12h8M20 4h-8v8h8V4z"/></svg>
            {{ 'Mijn QR Code'|t }}
            {% if wallet_balance %}
              <span style="margin-left:auto;font-size:11px;color:var(--muted);">€{{ wallet_balance }}</span>
            {% endif %}
          </a>
          <hr class="sf-dropdown-divider">
          <a href="{{ path('entity.user.cancel_form', {'user': current_uid}) }}"
             class="sf-dropdown-item danger" role="menuitem">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            {{ 'Account verwijderen'|t }}
          </a>
          <hr class="sf-dropdown-divider">
          <a href="{{ path('user.logout') }}" class="sf-dropdown-item" role="menuitem"
             style="color:var(--muted);">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            {{ 'Afmelden'|t }}
          </a>
        </div>
      </div>

    {% else %}
      <a href="{{ path('user.login') }}" class="sf-login-btn">
        {{ 'Inloggen'|t }}
      </a>
      {% if nav_show_register %}
        <a href="{{ path('registration_form.register') }}"
           style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--accent);color:white;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;">
          {{ 'Registreren'|t }}
        </a>
      {% endif %}
    {% endif %}

    {# Mobile hamburger #}
    <button id="sf-menu-toggle"
            style="display:none;background:transparent;border:none;cursor:pointer;padding:6px;color:rgba(255,255,255,.7);"
            aria-label="{{ 'Menu openen'|t }}"
            aria-expanded="false"
            aria-controls="sf-mobile-menu">
      <svg id="sf-icon-open" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="sf-icon-close" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

</header>

{# Mobile menu #}
<div id="sf-mobile-menu" class="sf-mobile-menu">
  <a href="{{ path('<front>') }}" class="sf-nav-link">{{ 'Home'|t }}</a>
  {% if not logged_in and nav_show_register %}
    <a href="{{ path('registration_form.register') }}" class="sf-nav-link">{{ 'Registreren'|t }}</a>
  {% endif %}
  {% if logged_in and nav_show_enroll %}
    <a href="{{ path('session_enrollment.enroll') }}" class="sf-nav-link">{{ 'Sessies'|t }}</a>
  {% endif %}
  {% if logged_in and is_company_user %}
    <a href="{{ path('company_invite.invite_form') }}" class="sf-nav-link">{{ 'Team'|t }}</a>
  {% endif %}
  {% if is_admin %}
    <a href="{{ path('session_management.create') }}" class="sf-nav-link">{{ 'Sessie aanmaken'|t }}</a>
    <a href="{{ path('session_management.end') }}" class="sf-nav-link">{{ 'Sessie beëindigen'|t }}</a>
  {% endif %}
  {% if logged_in %}
    <hr style="border:none;border-top:1px solid rgba(255,255,255,.08);margin:6px 0;">
    <a href="{{ path('qr_code.page') }}" class="sf-nav-link">{{ 'Mijn QR Badge'|t }}</a>
    <a href="{{ path('entity.user.edit_form', {'user': current_uid}) }}" class="sf-nav-link">{{ 'Mijn gegevens'|t }}</a>
    <a href="{{ path('user.logout') }}" class="sf-nav-link" style="color:rgba(255,255,255,.5);">{{ 'Afmelden'|t }}</a>
  {% else %}
    <a href="{{ path('user.login') }}" class="sf-nav-link">{{ 'Inloggen'|t }}</a>
  {% endif %}
</div>

{# ════════════════════════════════════════════════════════════ MAIN #}
<main role="main" style="flex:1;">
  <div class="sf-content">
    {{ page.content }}
  </div>
</main>

{# ════════════════════════════════════════════════════════════ FOOTER #}
<footer style="border-top:1px solid var(--line);background:var(--surface);padding:24px 40px;">
  <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">

    <div style="display:inline-flex;align-items:center;gap:8px;">
      <svg width="20" height="20" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="24" height="24" rx="7" fill="var(--ink)"/>
        <path d="M9 18.5L14 9.5L19 18.5" stroke="var(--bg)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="14" cy="14" r="1.6" fill="var(--accent)"/>
      </svg>
      <span style="font-weight:600;font-size:13px;color:var(--ink);">{{ site_name }}</span>
    </div>

    <p style="font-size:13px;color:var(--muted);margin:0;">
      {% if footer_text %}{{ footer_text }}{% else %}© 2026 {{ site_name }}{% endif %}
    </p>

    {% if social_facebook or social_instagram or social_linkedin or social_twitter %}
      <div style="display:flex;align-items:center;gap:12px;">
        {% if social_facebook %}
          <a href="{{ social_facebook }}" target="_blank" rel="noopener noreferrer"
             style="color:var(--muted);transition:color .15s;" aria-label="Facebook">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {% endif %}
        {% if social_instagram %}
          <a href="{{ social_instagram }}" target="_blank" rel="noopener noreferrer"
             style="color:var(--muted);transition:color .15s;" aria-label="Instagram">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {% endif %}
        {% if social_linkedin %}
          <a href="{{ social_linkedin }}" target="_blank" rel="noopener noreferrer"
             style="color:var(--muted);transition:color .15s;" aria-label="LinkedIn">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        {% endif %}
        {% if social_twitter %}
          <a href="{{ social_twitter }}" target="_blank" rel="noopener noreferrer"
             style="color:var(--muted);transition:color .15s;" aria-label="X / Twitter">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {% endif %}
      </div>
    {% endif %}

  </div>
</footer>

<style>
@media (max-width: 900px) {
  #sf-menu-toggle { display: flex !important; }
  .sf-header-nav { display: none !important; }
  #sf-account-wrapper { display: none !important; }
  .sf-login-btn { display: none !important; }
}
</style>
